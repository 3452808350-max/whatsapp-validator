# WhatsApp Number Validation Tool - Environment Variables
# Copy this file to .env and fill in your values

# Input/Output paths
WA_VALIDATOR_INPUT_PATH=data/input.csv
WA_VALIDATOR_OUTPUT_PATH=data/output.csv

# Validation settings
WA_VALIDATOR_DEFAULT_COUNTRY=US

# WhatsApp check mode (api/mock/estimated)
WA_VALIDATOR_WHATSAPP_MODE=mock

# API configuration (only needed for api mode)
WA_VALIDATOR_WHATSAPP_API_KEY=your_api_key_here

# Logging
WA_VALIDATOR_LOG_LEVEL=INFO